/*
 * secrets.h.example — copy to secrets.h and fill in your own values.
 *
 * NEVER commit the real secrets.h to git (already in .gitignore).
 *
 * Used by: launcher (AI Assistant — qwen3.5-omni-flash realtime / qwen3-asr-flash / qwen-turbo / qwen3-tts-flash)
 */
#ifndef SECRETS_H
#define SECRETS_H

/* ── Wi-Fi ───────────────────────────────────────────── */
#define WIFI_SSID "your_wifi_ssid"
#define WIFI_PSK  "your_wifi_password"

/* ── DashScope API key (sk-xxxx) ─────────────────────── */
/* Apply at https://dashscope.console.aliyun.com/                         */
/* Required model permissions (current active Plan-A pipeline):           */
/*   - qwen3-asr-flash             (ASR: speech-to-text)                  */
/*   - qwen-turbo                  (LLM: text generation)                 */
/*   - qwen3-tts-flash-realtime    (TTS: WebSocket realtime, voice=Cherry)*/
/* Optional (備用 Realtime 全双工，默认禁用):                              */
/*   - qwen3.5-omni-flash-realtime (one-shot ASR+LLM+TTS via WebSocket)   */
#define AI_API_KEY "sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

#endif /* SECRETS_H */
